DATABASE_URL=postgresql://ariadne:ariadne@127.0.0.1:5432/ariadne
WORKER_POLL_SECONDS=60
WORKER_BATCH_SIZE=5

# Ingestion guardrails. Items without published time are kept.
INGEST_MAX_ITEM_AGE_DAYS=7
INGEST_MAX_ITEMS_PER_FEED=100
INGEST_INTERVAL_SECONDS=14400

# Comma-separated RSS or Atom URLs. FreshRSS can expose feeds that fit here.
RSS_FEED_URLS=

# Comma-separated FreshRSS output feed URLs. These are read through the same RSS pipeline.
FRESHRSS_FEED_URLS=

# Optional FreshRSS private API access through the official Google Reader API.
FRESHRSS_API_BASE_URL=
FRESHRSS_API_USERNAME=
FRESHRSS_API_PASSWORD=
FRESHRSS_API_ITEM_LIMIT=50

# Optional. When missing, push jobs use dry-run mode and only write database records.
FEISHU_WEBHOOK_URL=
FEISHU_CALLBACK_TOKEN=

# Optional. When missing, Obsidian export jobs fail clearly instead of writing nowhere.
OBSIDIAN_VAULT_PATH=

# Push routing. High-importance items are pushed immediately; other items wait for digest by default.
PUSH_IMMEDIATE_MIN_IMPORTANCE=0.75
DIGEST_MIN_IMPORTANCE=-1
DIGEST_LIMIT=10
DIGEST_SCHEDULE_TIMES=09:00,17:00
DIGEST_SCHEDULE_HOURS=9,17
DIGEST_TIMEZONE=Asia/Shanghai
