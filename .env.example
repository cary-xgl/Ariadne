DATABASE_URL=postgresql://ariadne:ariadne@127.0.0.1:5432/ariadne
WORKER_POLL_SECONDS=5
WORKER_BATCH_SIZE=5

# Comma-separated RSS or Atom URLs. FreshRSS can expose feeds that fit here.
RSS_FEED_URLS=

# Comma-separated FreshRSS output feed URLs. These are read through the same RSS pipeline.
FRESHRSS_FEED_URLS=

# Optional. When missing, push jobs use dry-run mode and only write database records.
FEISHU_WEBHOOK_URL=
FEISHU_CALLBACK_TOKEN=

# Optional. When missing, Obsidian export jobs fail clearly instead of writing nowhere.
OBSIDIAN_VAULT_PATH=

# Push routing. High-importance items are pushed immediately; medium items wait for digest.
PUSH_IMMEDIATE_MIN_IMPORTANCE=0.75
DIGEST_MIN_IMPORTANCE=0.45
DIGEST_LIMIT=10
DIGEST_SCHEDULE_HOURS=9,17
DIGEST_TIMEZONE=Asia/Shanghai
